rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    
    function isManager() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/managers/$(request.auth.uid)) || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['manager', 'admin']
      );
    }

    function isStaff() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager', 'trainer'];
    }

    // Site isolation helper — only valid for 'get' (not 'list') operations
    function belongsToSite(data) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return (userDoc != null && userDoc.data.role == 'admin') || 
             (userDoc != null && data.siteId == userDoc.data.siteId);
    }

    // Rules for the 'users' collection (Profiles)
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isStaff());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Rules for 'admins' collection
    match /admins/{adminId} {
      allow read: if isSignedIn() && resource.data.email == request.auth.token.email;
      allow write: if false;
    }

    // Rules for 'managers'
    match /managers/{managerId} {
      allow read: if isSignedIn() && (
        resource.data.email == request.auth.token.email ||
        isManager()
      );
      allow create: if isAdmin() || isManager();
      allow update, delete: if isAdmin();
    }

    // Rules for 'trainers'
    match /trainers/{trainerId} {
      allow read: if true; // Public read for Trial booking page
      allow write: if isManager();
    }

    // Rules for 'services'
    match /services/{serviceId} {
      allow read: if true; // Public read for Trial booking page
      allow write: if isAdmin();
    }

    // Rules for 'clients'
    match /clients/{clientId} {
      // Staff can read all; clients can only read their own record
      allow list: if isSignedIn() && (
        isStaff() ||
        request.auth.token.email == resource.data.email
      );
      allow get: if isSignedIn() && (
        resource.data.uid == request.auth.uid || 
        resource.data.email == request.auth.token.email || 
        isStaff()
      );
      allow create: if true; // Allow unauthenticated trial booking leads
      allow update, delete: if isSignedIn() && (
        isStaff() ||
        resource.data.uid == request.auth.uid
      );
    }

    // Rules for 'sessions'
    // NOTE: 'resource.data' is NOT available in 'list' rules — only in 'get' rules.
    // For list operations, Firestore evaluates rules BEFORE fetching documents.
    // We enforce access by role; the client-side query filters (siteId, trainerId etc.) 
    // ensure the correct data scope is retrieved.
    match /sessions/{sessionId} {
      // ANY signed-in user can run a query (list). Trust client-side where() filters.
      // Unauthenticated access is allowed for trial booking availability checks.
      allow list: if true;

      // Individual document reads: allow staff, or if the user's uid/clientId is in the session
      allow get: if (
        isStaff() ||
        (isSignedIn() && resource.data.uids != null && request.auth.uid in resource.data.uids) ||
        (isSignedIn() && resource.data.client_ids != null && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clientId in resource.data.client_ids) ||
        resource.data.status == 'Scheduled' // Public availability check
      );

      allow create: if true; // Allow authenticated and trial bookings
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // Rules for 'settings'
    match /settings/{settingsId} {
      allow read: if true;
      allow write: if isManager();
    }

    // Rules for 'activity_logs'
    match /activity_logs/{logId} {
      allow list: if isManager();
      allow get: if isManager() && belongsToSite(resource.data);
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // Non-sensitive trainer busy slots for client-side conflict checking
    match /trainer_busy_slots/{slotId} {
      allow read: if true;
      allow write: if false; // Only manageable by Cloud Functions
    }
    
    match /off_days/{offDayId} {
      allow read: if true;
      allow write: if isAdmin() || isManager();
    }

    // Limits — Cloud Functions only
    match /rate_limits/{limitId} {
      allow read, write: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

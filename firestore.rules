rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getRole() {
      return getUserData().role;
    }

    function isAdmin() {
      return isSignedIn() && getRole() == 'admin';
    }

    function isManager() {
      return isSignedIn() && (getRole() == 'manager' || getRole() == 'admin');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Site isolation helper
    function belongsToSite(data) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return (userDoc != null && userDoc.data.role == 'admin') || 
             (userDoc != null && data.siteId == userDoc.data.siteId);
    }

    // Client Session Safety Validator
    // Prevents API manipulation by ensuring:
    // 1. Required fields are present and are strings
    // 2. The date is a properly formatted ISO string
    // 3. The date is not far in the past (allows 24h slack for timezone diffs)
    function isValidClientSession(data) {
      return data.keys().hasAll(['clientId', 'trainerId', 'date', 'time', 'siteId']) &&
             data.clientId is string &&
             data.trainerId is string &&
             data.date is string &&
             data.time is string &&
             data.siteId is string &&
             data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}T.*') &&
             timestamp.value(data.date).toMillis() >= (request.time.toMillis() - 86400000);
    }


    // Rules for the 'users' collection (Profiles)
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
    }

    // Rules for 'admins' collection
    match /admins/{adminId} {
      allow read: if isSignedIn() && resource.data.email == request.auth.token.email;
      allow write: if false;
    }

    // Rules for 'managers'
    match /managers/{managerId} {
      allow read: if isSignedIn() && (
        (resource.data.email == request.auth.token.email) ||
        (isManager() && belongsToSite(resource.data))
      );
      allow write: if isAdmin() && belongsToSite(request.resource.data);
    }

    // Rules for 'trainers'
    match /trainers/{trainerId} {
      allow read: if isSignedIn();
      allow write: if isManager() && belongsToSite(request.resource.data);
    }

    // Rules for 'services'
    match /services/{serviceId} {
      allow read: if isSignedIn();
      allow write: if isManager() && belongsToSite(request.resource.data);
    }

    // Rules for 'clients'
    match /clients/{clientId} {
      allow read: if isManager() && belongsToSite(resource.data) || (isSignedIn() && resource.data.email == request.auth.token.email);
      allow create: if isManager() && belongsToSite(request.resource.data) || (isSignedIn() && request.resource.data.email == request.auth.token.email);
      allow update, delete: if isManager() && belongsToSite(request.resource.data);
    }

    // Rules for 'sessions'
    match /sessions/{sessionId} {
      allow read: if isSignedIn() && (
        isManager() || 
        (getRole() == 'trainer' && resource.data.trainerId == getUserData().trainerId) ||
        (getRole() == 'client' && (resource.data.clientId == request.auth.uid || resource.data.clientId == getUserData().clientId))
      );
      
      allow create: if isSignedIn() && (
        isManager() ||
        (getRole() == 'trainer' && request.resource.data.trainerId == getUserData().trainerId) ||
        (getRole() == 'client' && (request.resource.data.clientId == request.auth.uid || request.resource.data.clientId == getUserData().clientId) && isValidClientSession(request.resource.data))
      );

      allow update: if isSignedIn() && (
        isManager() ||
        (getRole() == 'trainer' && resource.data.trainerId == getUserData().trainerId && request.resource.data.trainerId == getUserData().trainerId) ||
        (getRole() == 'client' && 
          (resource.data.clientId == request.auth.uid || resource.data.clientId == getUserData().clientId) && 
          (request.resource.data.clientId == request.auth.uid || request.resource.data.clientId == getUserData().clientId) &&
          isValidClientSession(request.resource.data)
        )
      );

      allow delete: if isSignedIn() && (
        isManager() ||
        (getRole() == 'trainer' && resource.data.trainerId == getUserData().trainerId) ||
        (getRole() == 'client' && (resource.data.clientId == request.auth.uid || resource.data.clientId == getUserData().clientId))
      );
    }

    // Rules for 'settings'
    match /settings/{settingsId} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }

    // Rules for 'activity_logs'
    match /activity_logs/{logId} {
      allow read: if isManager();
      allow write: if isSignedIn();
    }

    // New: Non-sensitive trainer busy slots for client-side conflict checking
    match /trainer_busy_slots/{slotId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable by Cloud Functions
    }
    
    match /off_days/{offDayId} {
      allow read: if isSignedIn();
      allow write: if (isAdmin() || isManager());
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Limits
    match /rate_limits/{limitId} {
      allow read, write: if false; // Only Cloud Functions can access this
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getRole() {
      // Use a direct path for role checking to avoid helper recursion
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    
    function isManager() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/managers/$(request.auth.uid)) || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['manager', 'admin']
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Site isolation helper
    function belongsToSite(data) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return (userDoc != null && userDoc.data.role == 'admin') || 
             (userDoc != null && data.siteId == userDoc.data.siteId);
    }

    // Client Session Safety Validator
    // Prevents API manipulation by ensuring:
    // 1. Required fields are present and are strings
    // 2. The date is a properly formatted ISO string
    // 3. The date is not far in the past (allows 24h slack for timezone diffs)
    function isValidClientSession(data) {
      return data.keys().hasAll(['clientId', 'trainerId', 'date', 'time', 'siteId']) &&
             data.clientId is string &&
             data.trainerId is string &&
             data.date is string &&
             data.time is string &&
             data.siteId is string &&
             data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}T.*') &&
             timestamp.value(data.date).toMillis() >= (request.time.toMillis() - 86400000);
    }


    // Rules for the 'users' collection (Profiles)
    match /users/{userId} {
      // Direct anchor to 'admins' collection to avoid recursive role-checking helpers
      allow read: if isSignedIn() && (request.auth.uid == userId || exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }

    // Rules for 'admins' collection
    match /admins/{adminId} {
      allow read: if isSignedIn() && resource.data.email == request.auth.token.email;
      allow write: if false;
    }

    // Rules for 'managers'
    match /managers/{managerId} {
      allow read: if isSignedIn() && (
        (resource.data.email == request.auth.token.email) ||
        (isManager() && belongsToSite(resource.data))
      );
      allow write: if isAdmin() && belongsToSite(request.resource.data);
    }

    // Rules for 'trainers'
    match /trainers/{trainerId} {
      allow read: if isSignedIn();
      allow write: if isManager() && belongsToSite(request.resource.data);
    }

    // Rules for 'services'
    match /services/{serviceId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Rules for 'clients'
    match /clients/{clientId} {
      // Prioritize direct UID/Email check to avoid get() overhead for clients
      allow read: if isSignedIn() && (
        resource.data.uid == request.auth.uid || 
        resource.data.email == request.auth.token.email || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager', 'trainer'])
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager']
      );
    }

    function getService(serviceId) {
      return get(/databases/$(database)/documents/services/$(serviceId)).data;
    }

    // Rules for 'sessions'
    match /sessions/{sessionId} {
      allow list: if isSignedIn() && (
        // Administrative Maintenance: Allow global list for repair tools
        isAdmin() ||
        // Staff check: Must belong to the site or be a global admin/manager
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager', 'trainer'] && 
         (resource.data.siteId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.siteId || resource.data.siteId == 'invictus-booking')) ||
        // Client check: Naturally restricted by their required 'uids' query filter
        (request.auth.uid in resource.data.uids)
      );

      // 2. Individual Document Fetch (Can be complex)
      allow get: if isSignedIn() && (
        (resource.data.uids != null && request.auth.uid in resource.data.uids) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager'] ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clientId in resource.data.client_ids
        ))
      );
      
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // Rules for 'settings'
    match /settings/{settingsId} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }

    // Rules for 'activity_logs'
    match /activity_logs/{logId} {
      allow read: if isManager() && belongsToSite(resource.data);
      allow write: if false;
    }

    // New: Non-sensitive trainer busy slots for client-side conflict checking
    match /trainer_busy_slots/{slotId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable by Cloud Functions
    }
    
    match /off_days/{offDayId} {
      allow read: if isSignedIn();
      allow write: if (isAdmin() || isManager());
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Limits
    match /rate_limits/{limitId} {
      allow read, write: if false; // Only Cloud Functions can access this
    }
  }
}
